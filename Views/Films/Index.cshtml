@model List<FilmCatalogue.Models.Film>
@{
    ViewData["Title"] = "Films Catalogue";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Films catalogue</h2>
    <a asp-action="Create" class="btn btn-success btn-lg">
        <i class="fas fa-plus"></i> Add new film
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        <h4>No films in the catalogue</h4>
        <p>Add the first film with the button above!</p>
        <a asp-action="Create" class="btn btn-primary">Start now</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Genre</th>
                    <th>Year</th>
                    <th>Studios</th>
                    <th>Rating</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var film in Model.OrderByDescending(f => f.Score))
                {
                    <tr>
                        <td>
                            <strong>@film.Title</strong><br />
                            <small class="text-muted">@film.ReleaseDate.ToString("dd.MM.yyyy")</small>
                        </td>
                        <td>
                            <span class="badge bg-primary">@film.Genre.Name</span>
                        </td>
                        <td>@film.ReleaseDate.Year</td>
                        <td>@film.Studio</td>
                        <td>
                            <div class="progress" style="height: 25px;">
                                <div class="progress-bar @(film.Score >= 90 ? "bg-success" : film.Score >= 70 ? "bg-warning" : "bg-secondary")"
                                     role="progressbar" style="width: @(film.Score)%"
                                     aria-valuenow="@film.Score" aria-valuemin="0" aria-valuemax="100">
                                    @film.Score/100
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm" role="group">
                                <a asp-action="Details" asp-route-id="@film.Id"
                                   class="btn btn-info" title="View">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@film.Id"
                                   class="btn btn-warning" title="Edit">
                                    <i class="fas fa-edit"></i>
                                </a>


                                <!-- -->
                                <form asp-action="Delete" asp-route-id="@film.Id" method="post"
                                      style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger"
                                            onclick="return confirm('Are you sure you want to delete \" @film.Title\"?')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Statistics -->
    <div class="row mt-4">
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">@Model.Count</h5>
                    <p class="card-text">Total films</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center @(Model.Average(f => f.Score) >= 80 ? "border-success" : "")">
                <div class="card-body">
                    <h5 class="card-title">@Model.Average(f => f.Score)</h5>
                    <p class="card-text">Average rating</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">@Model.Max(f => f.Score)</h5>
                    <p class="card-text">Best</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">@Model.Min(f => f.Score)</h5>
                    <p class="card-text">Worst</p>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}